# ── NoteMind Backend Environment Variables ────────────────────────────────────
# Copy this file to .env and fill in your values before starting the server.

# Google Gemini API key (required for answer generation)
# Free tier: 1,500 requests/day — no credit card needed
# Get yours at: https://aistudio.google.com/app/apikey
GCP_API_KEY=your_api_key_here

# Embedding backend (optional — default 'auto' loads MiniLM)
# Options: auto | minilm | tfidf
# Use 'tfidf' only if sentence-transformers cannot be installed.
# WARNING: tfidf disables true semantic search (keyword-only mode).
EMBED_BACKEND=auto

# JWT secret — change this to a random 32-char string in production
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_use_secrets_token_hex_32